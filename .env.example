# Database Configuration
DB_HOST=aaact-rmt-db
DB_PORT=3306
DB_USER=your_database_user
DB_PASS=your_database_password
DB_NAME=aaact
DB_SSL_MODE=DISABLED
# Optional CA bundle path when your environment requires explicit MySQL TLS trust configuration
DB_SSL_CA=

# Local Docker database only
MYSQL_ROOT_PASSWORD=your_mysql_root_password

# Runtime Environment
APP_ENV=development

# Application Configuration
PORT=8080
APP_BASE_URL=

# Timezone Configuration
TZ=America/New_York

# CORS Configuration
# Comma-separated list of allowed origins (e.g. https://example.canada.ca,https://intranet.example.ca)
CORS_ALLOWED_ORIGINS=

# GC Notify Email Integration
# Obtain from https://notification.canada.ca — not yet enabled, see docs/future/006-gcnotify-integration.md
GCNOTIFY_API_KEY=your_gc_notify_api_key
GCNOTIFY_TEMPLATE_ID=your_notification_template_id
GCNOTIFY_TEST_EMAIL=your_test_email@example.com

# GC Notify template overrides (optional)
GCNOTIFY_TEMPLATE_REQUEST_TEAM_EN=
GCNOTIFY_TEMPLATE_REQUEST_TEAM_FR=
GCNOTIFY_TEMPLATE_REQUEST_AFTERFACT_TEAM_EN=
GCNOTIFY_TEMPLATE_REQUEST_AFTERFACT_TEAM_FR=
GCNOTIFY_TEMPLATE_REQUEST_AAACT=
GCNOTIFY_TEMPLATE_REQUEST_CLIENT_EN=
GCNOTIFY_TEMPLATE_REQUEST_CLIENT_FR=
GCNOTIFY_TEMPLATE_REQUEST_DEFAULT_TEAM_EN=
GCNOTIFY_TEMPLATE_REQUEST_DEFAULT_TEAM_FR=
GCNOTIFY_TEMPLATE_REQUEST_DEFAULT_CLIENT_EN=
GCNOTIFY_TEMPLATE_REQUEST_DEFAULT_CLIENT_FR=
GCNOTIFY_TEMPLATE_RESOLVED_TEAM_EN=
GCNOTIFY_TEMPLATE_RESOLVED_TEAM_FR=
GCNOTIFY_TEMPLATE_RESOLVED_CLIENT_EN=
GCNOTIFY_TEMPLATE_RESOLVED_CLIENT_FR=
GCNOTIFY_TEMPLATE_STATUS_CHANGED_CLIENT_EN=
GCNOTIFY_TEMPLATE_STATUS_CHANGED_CLIENT_FR=
GCNOTIFY_TEMPLATE_REASSIGNED_TEAM_EN=
GCNOTIFY_TEMPLATE_REASSIGNED_TEAM_FR=
GCNOTIFY_TEMPLATE_REASSIGNED_CLIENT_EN=
GCNOTIFY_TEMPLATE_REASSIGNED_CLIENT_FR=

# Notification delivery controls
# live: send to intended recipients
# redirect: send to the logged-in user when available, otherwise to the override addresses below
# disabled: do not send notifications
NOTIFY_MODE=redirect
# true: in redirect mode, always use override emails first (recommended for Team and safelist API keys)
# false: in redirect mode, try logged-in user first, then overrides
NOTIFY_REDIRECT_FORCE_OVERRIDE=false
NOTIFY_OVERRIDE_EMAIL=
NOTIFY_OVERRIDE_CLIENT_EMAIL=
NOTIFY_OVERRIDE_INTERNAL_EMAIL=
