# Database Configuration
DB_HOST=aaact-rmt-db
DB_USER=your_database_user
DB_PASS=your_database_password
DB_NAME=aaact
MYSQL_ROOT_PASSWORD=your_mysql_root_password

# Application Configuration
PORT=8080

# Timezone Configuration
TZ=America/New_York

# CORS Configuration
# Comma-separated list of allowed origins (e.g. https://example.canada.ca,https://intranet.example.ca)
CORS_ALLOWED_ORIGINS=

# GC Notify Email Integration
# Obtain from https://notification.canada.ca — not yet enabled, see docs/future/006-gcnotify-integration.md
GCNOTIFY_API_KEY=your_gc_notify_api_key
GCNOTIFY_TEMPLATE_ID=your_notification_template_id
GCNOTIFY_TEST_EMAIL=your_test_email@example.com
